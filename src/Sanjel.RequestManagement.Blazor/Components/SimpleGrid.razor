@using Syncfusion.Blazor.Grids

<SfGrid DataSource="@GridData" AllowPaging="true" PageSize="25">
    <GridColumns>
        <GridColumn Field="Id" HeaderText="ID" Width="80"></GridColumn>
        <GridColumn Field="Name" HeaderText="Name" Width="150"></GridColumn>
        <GridColumn Field="Status" HeaderText="Status" Width="120"></GridColumn>
    </GridColumns>
</SfGrid>