@page "/requests"
@using Sanjel.RequestManagement.Core.Entities
@using Sanjel.RequestManagement.Blazor.Components.Pages.Requests
@using Sanjel.RequestManagement.Blazor.Services
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Popups

<PageTitle>Program Requests Management</PageTitle>

<div class="requests-page">
	<div class="page-header">
		<h3>Program Requests</h3>
		<SfButton CssClass="e-primary" @onclick="this.HandleAddRequest">
			<i class="fas fa-plus"></i> Add New Request
		</SfButton>
	</div>

	<div class="grid-container">
		<SfGrid @ref="requestsGrid" DataSource="@requests" AllowPaging="true" AllowSorting="true" AllowFiltering="true"
						AllowResizing="true" Height="600">

			<GridPageSettings PageSize="20" PageSizes="@pageSizes"></GridPageSettings>
			<GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.FilterBar"></GridFilterSettings>

			<GridColumns>
				<GridColumn Field="@nameof(Request.RequestId)" HeaderText="Request ID" Width="120" IsPrimaryKey="true">
				</GridColumn>

				<GridColumn Field="@nameof(Request.Status)" HeaderText="Status" Width="130">
					<Template>
						@{
							var status = (context as Request)?.Status;
							var cssClass = GetStatusCssClass(status);
						}
						<span class="status-badge @cssClass">@status</span>
					</Template>
				</GridColumn>

				<GridColumn Field="@nameof(Request.Priority)" HeaderText="Priority" Width="110">
					<Template>
						@{
							var priority = (context as Request)?.Priority;
							var cssClass = GetPriorityCssClass(priority);
						}
						<span class="priority-badge @cssClass">@priority</span>
					</Template>
				</GridColumn>

				<GridColumn Field="@nameof(Request.ClientId)" HeaderText="Client ID" Width="120">
				</GridColumn>

				<GridColumn Field="@nameof(Request.SourceEmail)" HeaderText="Source Email" Width="200">
				</GridColumn>

				<GridColumn Field="@nameof(Request.AssignedEngineerId)" HeaderText="Assigned Engineer" Width="150">
				</GridColumn>

				<GridColumn Field="@nameof(Request.CreatedDate)" HeaderText="Created Date" Width="150" Format="MM/dd/yyyy">
				</GridColumn>

				<GridColumn Field="@nameof(Request.AcknowledgmentDate)" HeaderText="Acknowledgment Date" Width="170"
										Format="MM/dd/yyyy">
				</GridColumn>

				<GridColumn HeaderText="Actions" Width="150">
					<Template>
						@{
							var request = context as Request;
						}
						<div class="action-buttons">
							<SfButton CssClass="e-small e-info" @onclick="() => HandleEditRequest(request)">
								<i class="fas fa-edit"></i>
							</SfButton>
							<SfButton CssClass="e-small e-danger" @onclick="() => HandleDeleteRequest(request)">
								<i class="fas fa-trash"></i>
							</SfButton>
						</div>
					</Template>
				</GridColumn>
			</GridColumns>
		</SfGrid>
	</div>

	<!-- Edit Modal -->
	<RequestEditModal @ref="editModal" IsVisible="@isEditModalVisible" RequestModel="@currentRequest"
										OnSave="this.HandleSaveRequestAsync" OnCancel="this.HandleCancelEdit" />

	<!-- Delete Confirmation Dialog -->
	<SfDialog @ref="deleteDialog" Target="#requests-page" Width="400px" Height="200px" IsModal="true"
						Visible="@isDeleteDialogVisible" ShowCloseIcon="false" AllowDragging="false">
		<DialogTemplates>
			<Header>Confirm Delete</Header>
			<Content>
				<p>Are you sure you want to delete request <strong>@currentRequest?.RequestId</strong>?</p>
				<p>This action cannot be undone.</p>
			</Content>
		</DialogTemplates>
		<DialogButtons>
			<DialogButton Content="Cancel" CssClass="e-flat" OnClick="this.HandleCancelDelete" />
			<DialogButton Content="Delete" CssClass="e-danger e-flat" IsPrimary="true"
										OnClick="this.HandleConfirmDeleteAsync" />
		</DialogButtons>
	</SfDialog>

	<!-- Loading Overlay -->
	@if (isLoading)
	{
		<div class="loading-overlay">
			<div class="loading-spinner">
				<i class="fas fa-spinner fa-spin"></i>
				<span>Loading...</span>
			</div>
		</div>



	}
</div>