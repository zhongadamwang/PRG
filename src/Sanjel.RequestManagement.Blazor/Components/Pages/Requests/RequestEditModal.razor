@using Sanjel.RequestManagement.Entities.Entities
@using Syncfusion.Blazor.Popups
@using Syncfusion.Blazor.Inputs
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.Buttons

<SfDialog @bind-Visible="this.IsVisible" Width="800px" Height="auto" ShowCloseIcon="true" IsModal="true"
					CloseOnEscape="true">
	<DialogTemplates>
		<Header>
			<div class="dialog-header">@this.DialogTitle</div>
		</Header>
		<Content>
			@if (this.RequestModel != null)
			{
				<div class="modal-form">
					<div class="form-row">
						<div class="form-group">
							<label class="form-label">Request ID</label>
							<SfTextBox @bind-Value="@this.RequestModel.RequestId" Placeholder="Auto-generated"
												 Readonly="@(!this.IsNewRequest)" CssClass="form-input">
							</SfTextBox>
						</div>

						<div class="form-group">
							<label class="form-label">Status <span class="required">*</span></label>
							<SfDropDownList @bind-Value="@this.RequestModel.Status" DataSource="@this.StatusOptions"
															CssClass="form-input">
								<DropDownListFieldSettings Value="Value" Text="Text"></DropDownListFieldSettings>
							</SfDropDownList>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group">
							<label class="form-label">Priority <span class="required">*</span></label>
							<SfDropDownList @bind-Value="@this.RequestModel.Priority" DataSource="@this.PriorityOptions"
															CssClass="form-input">
								<DropDownListFieldSettings Value="Value" Text="Text"></DropDownListFieldSettings>
							</SfDropDownList>
						</div>

						<div class="form-group">
							<label class="form-label">Client ID <span class="required">*</span></label>
							<SfTextBox @bind-Value="@this.RequestModel.ClientId" Placeholder="Enter client ID" CssClass="form-input">
							</SfTextBox>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group full-width">
							<label class="form-label">Source Email <span class="required">*</span></label>
							<SfTextBox @bind-Value="@this.RequestModel.SourceEmail" Placeholder="Enter source email"
												 CssClass="form-input">
							</SfTextBox>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group">
							<label class="form-label">Assigned Engineer ID <span class="required">*</span></label>
							<SfTextBox @bind-Value="@this.RequestModel.AssignedEngineerId" Placeholder="Enter engineer ID"
												 CssClass="form-input">
							</SfTextBox>
						</div>

						<div class="form-group">
							<label class="form-label">Assigned By <span class="required">*</span></label>
							<SfTextBox @bind-Value="@this.RequestModel.AssignedBy" Placeholder="Enter manager ID" CssClass="form-input">
							</SfTextBox>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group">
							<label class="form-label">Created Date</label>
							<SfDateTimePicker @bind-Value="@this.RequestModel.CreatedDate" Format="MM/dd/yyyy HH:mm" Readonly="true"
																CssClass="form-input">
							</SfDateTimePicker>
						</div>

						<div class="form-group">
							<label class="form-label">Acknowledgment Date</label>
							<SfDateTimePicker @bind-Value="@this.AcknowledgmentDate" Format="MM/dd/yyyy HH:mm" AllowEdit="true"
																CssClass="form-input">
							</SfDateTimePicker>
						</div>
					</div>

					<div class="form-row">
						<div class="form-group">
							<label class="form-label">Completion Date</label>
							<SfDateTimePicker @bind-Value="@this.CompletionDate" Format="MM/dd/yyyy HH:mm" AllowEdit="true"
																CssClass="form-input">
							</SfDateTimePicker>
						</div>
					</div>

					<!-- Validation Messages -->
					@if (this.ValidationMessages.Any())
					{
						<div class="validation-summary">
							<ul>
								@foreach (var message in this.ValidationMessages)
								{
									<li>@message</li>
								}
							</ul>
						</div>

					}
				</div>
			}
		</Content>
		<FooterTemplate>
			<div class="modal-footer">
				<SfButton @onclick="this.HandleSaveAsync" IsPrimary="true" Disabled="@this.IsProcessing" CssClass="btn-save">
					@if (this.IsProcessing)
					{
						<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
					}
					@this.SaveButtonText
				</SfButton>
				<SfButton @onclick="this.HandleCancelAsync" Disabled="@this.IsProcessing" CssClass="btn-cancel">
					Cancel
				</SfButton>
			</div>
		</FooterTemplate>
	</DialogTemplates>
	<DialogEvents Opened="this.OnDialogOpen" Closed="this.OnDialogClose"></DialogEvents>
</SfDialog>