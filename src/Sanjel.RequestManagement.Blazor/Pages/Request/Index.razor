@page "/request"
@rendermode InteractiveServer
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.DropDowns
@using Syncfusion.Blazor.Inputs
@using Sanjel.RequestManagement.Entities.Entities
@using Sanjel.RequestManagement.Repositories.Common
@using Sanjel.RequestManagement.Blazor.Pages.Request.ViewModels
@using Sanjel.RequestManagement.Blazor.Pages.Request.Services

<PageTitle>Request Management</PageTitle>

<div class="request-list-page">
	<div class="page-header">
		<h1>Request Management</h1>
		<div class="header-actions">
			<SfButton CssClass="e-primary" OnClick="CreateNewRequest">
				<ChildContent>
					<span class="e-btn-icon e-icons e-plus"></span>
					<span>New Request</span>
				</ChildContent>
			</SfButton>
		</div>
	</div>

	<div class="search-bar">
		<SfTextBox Placeholder="Search requests..." FloatLabelType="FloatLabelType.Never"
							 @bind-Value="ViewModel.SearchTerm"></SfTextBox>
	</div>

	<div class="filter-panel">
		<div class="filter-row">
			<div class="filter-group">
				<label>Status</label>
				<SfDropDownList TValue="StatusEnum?" TItem="StatusEnum" Placeholder="All Statuses" DataSource="@statusOptions"
												@bind-Value="ViewModel.StatusFilter">
				</SfDropDownList>
			</div>

			<div class="filter-group">
				<label>Priority</label>
				<SfDropDownList TValue="PriorityEnum?" TItem="PriorityEnum" Placeholder="All Priorities"
												DataSource="@priorityOptions" @bind-Value="ViewModel.PriorityFilter">
				</SfDropDownList>
			</div>

			<div class="filter-group">
				<label>Client ID</label>
				<SfTextBox Placeholder="Filter by Client ID" @bind-Value="ViewModel.ClientIdFilter"></SfTextBox>
			</div>

			<div class="filter-group">
				<label>Engineer</label>
				<SfTextBox Placeholder="Filter by Engineer" @bind-Value="ViewModel.AssignedEngineerIdFilter"></SfTextBox>
			</div>
		</div>

		<div class="filter-actions">
			<SfButton CssClass="e-outline" OnClick="this.ApplyFiltersAsync">
				<span class="e-btn-icon e-icons e-search"></span>
				Apply Filters
			</SfButton>
			<SfButton CssClass="e-outline" OnClick="this.ClearFiltersAsync">
				<span class="e-btn-icon e-icons e-refresh"></span>
				Clear
			</SfButton>
		</div>
	</div>

	<div class="data-grid-container">
		@if (isLoading)
		{
			<div class="loading-spinner">
				<div class="spinner"></div>
				<p>Loading requests...</p>
			</div>
		}
		else if (pagedResult?.Items.Count == 0)
		{
			<div class="empty-state">
				<span class="e-icons e-empty"></span>
				<h3>No Requests Found</h3>
				<p>@GetEmptyStateMessage()</p>
				@if (!ViewModel.HasActiveFilters())
				{
					<SfButton CssClass="e-primary" OnClick="CreateNewRequest">Create First Request</SfButton>
				}
				else
				{
					<SfButton CssClass="e-outline" OnClick="this.ClearFiltersAsync">Clear Filters</SfButton>
				}
			</div>
		}
		else
		{
			<SfGrid DataSource="@this.pagedResult?.Items" TValue="Request" AllowSorting="true" AllowPaging="true"
							Toolbar="@(new List<string>() { "Search" })" AllowFiltering="true" FilterSettings="@filterSettings"
							AllowSelection="true" RowSelected="OnRowSelected" RowDeselected="OnRowDeselected">
				<GridEvents OnActionBegin="this.OnActionBeginAsync" TValue="Request"></GridEvents>
				<GridSortSettings Columns="@this.initialSortColumns" AllowUnsort="true"></GridSortSettings>
				<GridSelectionSettings Type="@Syncfusion.Blazor.Grids.SelectionType.Multiple"></GridSelectionSettings>
				<GridPageSettings PageSizes="@this.pageSizes" PageSize="@this.ViewModel.PageSize"></GridPageSettings>

				<GridColumns>

					<GridColumn Field="@nameof(Request.RequestId)" HeaderText="Request ID" Width="120" IsPrimaryKey="true">
						<Template>
							@{
								var request = (context as Request);
								<a href="@GetDetailUrl(request?.RequestId)" class="request-link">
									@((context as Request)?.RequestId)
								</a>
							}
						</Template>
					</GridColumn>

					<GridColumn Field="@nameof(Request.Status)" HeaderText="Status" Width="120">
						<Template>
							@((MarkupString)GetStatusBadge((context as Request)?.Status))
						</Template>
					</GridColumn>

					<GridColumn Field="@nameof(Request.Priority)" HeaderText="Priority" Width="100">
						<Template>
							@((MarkupString)GetPriorityBadge((context as Request)?.Priority))
						</Template>
					</GridColumn>

					<GridColumn Field="@nameof(Request.ClientId)" HeaderText="Client" Width="100"></GridColumn>

					<GridColumn Field="@nameof(Request.SourceEmail)" HeaderText="Source Email" Width="200"></GridColumn>

					<GridColumn Field="@nameof(Request.AssignedEngineerId)" HeaderText="Assigned Engineer" Width="150"></GridColumn>

					<GridColumn Field="@nameof(Request.AssignedBy)" HeaderText="Assigned By" Width="120"></GridColumn>

					<GridColumn Field="@nameof(Request.CreatedDate)" HeaderText="Created Date" Width="140" Format="yyyy-MM-dd HH:mm"
											Type="ColumnType.DateTime"></GridColumn>

					<GridColumn Field="@nameof(Request.AcknowledgmentDate)" HeaderText="Acknowledgment" Width="140"
											Format="yyyy-MM-dd" Type="ColumnType.DateTime">
						<Template>
							@(((context as Request)?.AcknowledgmentDate == default) ? "-" : ((context as
						Request)?.AcknowledgmentDate.ToString("yyyy-MM-dd")))
						</Template>
					</GridColumn>

					<GridColumn Field="@nameof(Request.CompletionDate)" HeaderText="Completion" Width="140" Format="yyyy-MM-dd"
											Type="ColumnType.DateTime">
						<Template>
							@(((context as Request)?.CompletionDate == default) ? "-" : ((context as
						Request)?.CompletionDate.ToString("yyyy-MM-dd")))
						</Template>
					</GridColumn>

					<GridColumn HeaderText="Actions" Width="150" TextAlign="TextAlign.Center">
						<Template>
							<div class="action-buttons">
								<SfButton CssClass="e-flat e-icon-btn" OnClick="@(e => ViewDetail(context as Request))" title="View">
									<span class="e-icons e-eye"></span>
								</SfButton>
								<SfButton CssClass="e-flat e-icon-btn" OnClick="@(e => EditRequest(context as Request))" title="Edit">
									<span class="e-icons e-edit"></span>
								</SfButton>
								<SfButton CssClass="e-flat e-icon-btn danger-btn"
													OnClick="@(e => this.DeleteRequestAsync(context as Request))" title="Delete">
									<span class="e-icons e-delete"></span>
								</SfButton>
							</div>
						</Template>
					</GridColumn>
				</GridColumns>
			</SfGrid>
		}
	</div>

	<div class="summary-bar">
		<span class="total-count">Showing @GetDisplayRange() of @pagedResult?.TotalCount total requests</span>

		<div class="batch-actions" style="@(selectedRequests.Count > 0 ? "display: flex;" : "display: none;")">
			<span>@selectedRequests.Count selected</span>
			<SfButton CssClass="e-outline" OnClick="this.BatchDeleteAsync" Disabled="isLoading">
				<span class="e-btn-icon e-icons e-delete"></span>
				Delete Selected
			</SfButton>
		</div>
	</div>
</div>