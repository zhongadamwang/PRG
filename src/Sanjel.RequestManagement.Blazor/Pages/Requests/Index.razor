@page "/requests"
@rendermode InteractiveServer
@using Sanjel.RequestManagement.Entities.Entities
@using Sanjel.RequestManagement.Blazor.Pages.Requests.Components

<PageTitle>Requests</PageTitle>

<h1>Requests</h1>

<p class="text-secondary mb-4">Monitor the current request pipeline with live repository data and a quick operational
	summary.</p>

	@if (!string.IsNullOrWhiteSpace(ErrorMessage))
	{
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			@ErrorMessage
			<button type="button" class="btn-close" @onclick="DismissMessages" aria-label="Close"></button>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(SuccessMessage))
	{
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			@SuccessMessage
			<button type="button" class="btn-close" @onclick="DismissMessages" aria-label="Close"></button>
		</div>
	}

	@if (IsLoading)
	{
		<div class="alert alert-info" role="status">
			Loading request data...
		</div>
	}
	else
	{
		<section class="row g-3 mb-4">
			@foreach (var metric in SummaryMetrics)
			{
				<div class="col-12 col-md-6 col-xl-3">
					<article class="request-summary-card card h-100 shadow-sm">
						<div class="card-body">
							<p class="request-summary-label mb-2">@metric.Label</p>
							<p class="request-summary-value mb-1">@metric.Value</p>
							<p class="request-summary-detail mb-0">@metric.Detail</p>
						</div>
					</article>
				</div>
			}
		</section>

		<section class="card shadow-sm">
			<div class="card-body">
				<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-lg-between gap-3 mb-3">
					<div>
						<h2 class="h4 mb-1">Request Queue</h2>
						<p class="text-secondary mb-0">This view uses the registered request repository, so development runs show mock
							data automatically.</p>
						</div>
						<div class="d-flex gap-2">
							<button type="button" class="btn btn-primary" @onclick="@this.ShowCreateDialog">
								New Request
							</button>
							<button type="button" class="btn btn-outline-primary" @onclick="@this.RefreshAsync">
								Refresh
							</button>
						</div>
					</div>

					@if (Requests.Count == 0)
					{
						<div class="alert alert-warning mb-0" role="alert">
							No requests are available yet.
						</div>
					}
					else
					{
						<SfGrid TValue="Request" DataSource="@Requests" AllowPaging="true" AllowSorting="true" Width="100%">
							<GridPageSettings PageSize="10" />
							<GridColumns>
								<GridColumn Field="@nameof(Request.RequestId)" HeaderText="Request ID" Width="140" />
								<GridColumn Field="@nameof(Request.ClientId)" HeaderText="Client" Width="150" />
								<GridColumn Field="@nameof(Request.Status)" HeaderText="Status" Width="140" />
								<GridColumn Field="@nameof(Request.Priority)" HeaderText="Priority" Width="130" />
								<GridColumn Field="@nameof(Request.AssignedEngineerId)" HeaderText="Engineer" Width="140" />
								<GridColumn Field="@nameof(Request.CreatedDate)" HeaderText="Created" Format="MMM dd, yyyy" Width="150" />
								<GridColumn HeaderText="Actions" Width="100">
									<Template>
										@{
											var request = context as Request;
										}
										<div class="d-flex gap-1">
											<button type="button" class="btn btn-sm btn-primary" @onclick="@(() => ShowEditDialog(request))">
												Edit
											</button>
											<button type="button" class="btn btn-sm btn-danger"
															@onclick="@(() => ShowDeleteConfirmationAsync(request))">
												Delete
											</button>
										</div>
									</Template>
								</GridColumn>
							</GridColumns>
						</SfGrid>
					}
				</div>
			</section>
		}

		<SfDialog Width="700px" Visible="@IsDialogVisible" ShowCloseIcon="true" IsModal="true" Header="@DialogTitle">
			<DialogTemplates>
				<Content>
					<RequestDialog ViewModel="DialogViewModel" IsEdit="IsEditMode" OnSave="OnDialogSaveAsync"
												 OnCancel="OnDialogCancel" />
				</Content>
			</DialogTemplates>
		</SfDialog>

		<!-- Delete Confirmation Dialog -->
		<SfDialog Width="500px" Visible="@IsDeleteConfirmationVisible" ShowCloseIcon="false" IsModal="true"
							Header="Confirm Delete">
			<DialogTemplates>
				<Content>
					@if (RequestToDelete != null)
					{
						<div class="p-3">
							<div class="mb-3">
								<i class="fas fa-exclamation-triangle text-warning me-2"></i>
								<strong>Are you sure you want to delete this request?</strong>
							</div>
							<div class="mb-3">
								<table class="table table-borderless table-sm">
									<tbody>
										<tr>
											<td class="fw-bold">Request ID:</td>
											<td>@RequestToDelete.RequestId</td>
										</tr>
										<tr>
											<td class="fw-bold">Client:</td>
											<td>@RequestToDelete.ClientId</td>
										</tr>
										<tr>
											<td class="fw-bold">Status:</td>
											<td>
												<span class="badge @GetStatusBadgeClass(RequestToDelete.Status)">
													@RequestToDelete.Status
												</span>
											</td>
										</tr>
										<tr>
											<td class="fw-bold">Created:</td>
											<td>@RequestToDelete.CreatedDate.ToString("MMM dd, yyyy")</td>
										</tr>
									</tbody>
								</table>
							</div>
							@if (!string.IsNullOrWhiteSpace(DeleteConstraintMessage))
							{
								<div class="alert alert-danger mb-3" role="alert">
									<i class="fas fa-ban me-2"></i>
									@DeleteConstraintMessage
								</div>
							}
							<div class="text-muted small">
								<strong>Warning:</strong> This action cannot be undone. The request and all associated data will be
								permanently removed.
							</div>
						</div>
					}
				</Content>
				<FooterTemplate>
					<div class="d-flex justify-content-end gap-2">
						<button type="button" class="btn btn-secondary" @onclick="OnDeleteCancel" disabled="@IsDeleting">
							Cancel
						</button>
						<button type="button" class="btn btn-danger" @onclick="OnDeleteConfirmAsync"
										disabled="@(IsDeleting || !string.IsNullOrWhiteSpace(DeleteConstraintMessage))">>
							@if (IsDeleting)
							{
								<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
								<span>Deleting...</span>
							}
							else
							{
								<i class="fas fa-trash me-2"></i>
								<span>Delete Request</span>
							}
						</button>
					</div>
				</FooterTemplate>
			</DialogTemplates>
		</SfDialog>